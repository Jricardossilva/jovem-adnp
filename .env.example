APP_NAME="Pelada da Igreja"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Banco de dados (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pelada
DB_USERNAME=root
DB_PASSWORD=

# Sessão / cache / fila
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Armazenamento das fotos
FILESYSTEM_DISK=public

# E-mail (opcional; útil para recuperação de senha do organizador)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="pelada@igreja.local"
MAIL_FROM_NAME="${APP_NAME}"
